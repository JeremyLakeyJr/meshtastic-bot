# Meshtastic AI DM Bot Configuration
# Copy this file to config.env and fill in your values

# MQTT Configuration
MQTT_HOST=46.10.220.106
MQTT_PORT=1883
MQTT_USER=bot
MQTT_PASS=your_mqtt_password_here

# Mesh Network Configuration
ROOT_FILTER=msh/#
DEFAULT_REGION=EU
DEFAULT_VERSION=2

# Response Configuration
CHUNK_BYTES=180
CHUNK_DELAY_SECONDS=1.2

# AI Configuration
AI_BACKEND=gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Email Configuration
GMAIL_EMAIL=meshtasticbot@gmail.com

# Choose authentication method: "oauth2_service_account", "oauth2_user_consent", or "app_password"
GMAIL_AUTH_METHOD=app_password

# For OAuth 2.0 Service Account: path to JSON file or JSON string
# GMAIL_AUTH_CREDENTIALS=/path/to/service-account.json
# OR
# GMAIL_AUTH_CREDENTIALS={"type": "service_account", "project_id": "...", ...}

# For OAuth 2.0 User Consent: path to token.json file
# GMAIL_AUTH_CREDENTIALS=token.json

# For App Password: the generated app password
GMAIL_AUTH_CREDENTIALS=your_app_password_here

# Optional: Session timeout in seconds
# SESSION_TIMEOUT=3600
\n# Enable serial connection to a physical Meshtastic node
SERIAL_ENABLED=False
\n# System prompt for the AI
# AI_SYSTEM_PROMPT="You are a Meshtastic DM bot with strict brevity rules.\n- Aim for ~250–450 characters total.\n- Never under 200 chars; never over 600 chars.\n- 1–3 short bullet points OR one concise paragraph.\n- No greetings/preamble/fluff; deliver facts/steps.\n- If listing steps, use '- <step>'.
